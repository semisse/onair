{
  "name": "onair",
  "version": "0.1.2",
  "description": "macOS menu bar app that turns on an ON AIR sign when you're on a Teams call",
  "main": "main.js",
  "author": "Today We Dream Tomorrow We Build",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build:native": "bash scripts/build-native.sh",
    "build:icons": "bash scripts/build-icons.sh",
    "build": "npm run build:native && npm run build:icons && electron-builder",
    "dist": "npm run build",
    "test": "jest",
    "postversion": "git push && git push --follow-tags"
  },
  "build": {
    "appId": "com.todaywedream.onair",
    "productName": "On Air",
    "files": [
      "main.js",
      "windows/**",
      "assets/**",
      "native/check-mic",
      "package.json"
    ],
    "asarUnpack": [
      "native/check-mic"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "On Air needs microphone access to detect when you're on a call.",
        "NSCameraUsageDescription": "On Air needs camera access to detect when your camera is active."
      }
    },
    "dmg": {
      "title": "On Air"
    }
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "jest": "^30.3.0",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "electron-store": "^11.0.2"
  }
}
